(* 
  FB_PLCDigitalOutputBinder 功能块
  功能：
  1. 把原始 IO 边界 `ST_PLCIO.Y*` 写回 PLC 运行时输出映像 `OUT[0..47]`。
  2. 当前块只负责“下发现场原始数字量输出”，不直接决定各输出点什么时候置位。
  3. 当前输出点位顺序固定按现场 IO 表绑定，若现场扩点或换点，必须同步修改本块和 `ST_PLCIO`。

  使用限制：
  1. 当前实现假定目标 PLC 运行时直接提供 `OUT[]` 输出映像数组。
  2. 本块应在 `PRG_MainControl` 每拍最后段调用，确保前面所有业务逻辑写入的 `Y*` 点位能在当前拍统一下发。
*)
FUNCTION_BLOCK FB_PLCDigitalOutputBinder
VAR_IN_OUT
    stPLC: ST_PLCIO; // 原始 PLC IO 共享边界；本块把逻辑层写入的 `Y*` 字段逐点刷新到现场 `OUT[]` 输出映像。
END_VAR

OUT[0] := stPLC.Y0;      // 把 `Y0` 下发到 `OUT[0]`，表示合模输出。
